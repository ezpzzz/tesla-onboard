# ─────────────────────────────────────────────────────────────────────────────
# Ready to Roll — environment configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy to `.env.local` and fill in real values to enable live Tesla sign-in.
# Everything except NEXT_PUBLIC_* is server-only and never reaches the browser.

# --- Host identity & contact -------------------------------------------------
# Guest-facing details for your listing. These are shown to renters, so they are
# NEXT_PUBLIC_* (they ship to the browser) — env keeps them out of source, not
# secret. If unset, the app falls back to generic placeholders.
NEXT_PUBLIC_COMPANY_NAME="Your Rental Co"
NEXT_PUBLIC_TAGLINE="Your Tesla, ready to roll."
NEXT_PUBLIC_HOST_NAME="Your host"
NEXT_PUBLIC_HOST_PHONE="555-555-0100"
NEXT_PUBLIC_SUPPORT_EMAIL="host@example.com"
NEXT_PUBLIC_ROADSIDE_PHONE="555-555-0199"

# --- Sign-in mode ------------------------------------------------------------
# "mock" → simulated consent screen + personas. No credentials. Default.
# "live" → real Tesla Fleet API OAuth (authorization-code flow).
NEXT_PUBLIC_TESLA_AUTH_MODE=mock

# --- Live Tesla Fleet API OAuth (only needed when AUTH_MODE=live) ------------
# Register an application at https://developer.tesla.com to obtain these.
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=

# Must EXACTLY match a redirect URI registered in the Tesla developer portal,
# and must be reachable over HTTPS (Tesla rejects most http origins). For local
# dev, use a tunnel (ngrok / cloudflared) and register that HTTPS URL.
#   prod:  https://your-app.example.com/auth/tesla/callback
#   dev:   https://<your-tunnel>.ngrok-free.app/auth/tesla/callback
TESLA_REDIRECT_URI=https://your-app.example.com/auth/tesla/callback

# Smallest scope that yields identity + the vehicle list. Add offline_access
# only if you later need to re-read without re-prompting the user.
TESLA_SCOPES=openid vehicle_device_data

# Regional Fleet API base, used as the OAuth `audience` and for data calls.
# Region is auto-discovered at runtime via /api/1/users/region, so this is just
# the starting point. NA shown; EU = ...prd.eu... ; CN = ...prd.cn...tesla.cn
TESLA_AUDIENCE=https://fleet-api.prd.na.vn.cloud.tesla.com

# Random 32+ char secret used to seal the session cookie (AES-256-GCM).
# Generate with:  openssl rand -hex 32
TESLA_SESSION_SECRET=

# --- Partner registration (optional) -----------------------------------------
# Only needed if Tesla requires partner-account registration / public-key
# hosting for your app. Generate keys with: node scripts/tesla-setup.mjs genkeys
# The public key is served at /.well-known/appspecific/com.tesla.3p.public-key.pem
# In serverless deploys, paste the PEM here (use \n for newlines) instead of the file.
# TESLA_PUBLIC_KEY_PEM=
# TESLA_APP_DOMAIN=your-app.vercel.app
